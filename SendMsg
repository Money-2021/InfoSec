// Send offline message via infastcture store/retrieve 

[TestMethod]
public void UseCase_sendMsg()
{
    SET_INFO();
    string folder = Environment.GetEnvironmentVariable("Envionment");
    string sin = Environment.GetEnvironmentVariable("TestA"); // HQ 
    string userTokenPath = @"D:\Examples\" + folder + "\\Token-" + sin + ".json";
    Fido.FidoProvider fp = new Fido.FidoProvider(userTokenPath);

    // MsgMe receiver token
    Fido.MsgMe m = new Fido.MsgMe(fp); // infastucture-less messaging
    string msgMeToken = m.Encode();

    // Battlefield forward observer -> Sender
    string device_sin = Environment.GetEnvironmentVariable("DeviceTestA");
    userTokenPath = @"D:\Examples\" + folder + "\\Token-" + sin + ".json";
    fp = new Fido.FidoProvider(userTokenPath);

    // Millitary Message SITREP
    string sitrep = "Date: 2026-04-25; Location: Sector Alpha; Units active: 3rd Infantry Battalion; Recent actions: Secured perimeter, identified enemy movement; Current status: All units operational.";
    // Create infastureless Message    
    Fido.MsgToken tkn = new Fido.MsgToken();
    tkn.Jti = Guid.NewGuid();
    tkn.Cnt = Encoding.UTF8.GetBytes(sitrep);
    tkn.Recsin = sin;
    tkn.Expire = DateTime.MaxValue; // Never expire test
    tkn.FileName = "sitrep.txt";
    tkn.Subject = "SITREP";
    string msg = tkn.Encode(fp, msgMeToken);

    // Post MsgToken to Infastruture store/retrieve
    StringContent content = new StringContent(msg);

    Uri _baseUri = new Uri(fp.Audience());
    HttpClient _httpClient = new HttpClient();
    string _relativeUrl = "api/SendMsg";
    Uri _uri = new Uri(_baseUri, _relativeUrl);
    _httpClient.BaseAddress = _baseUri;
    // Add User Jwtoken
    _httpClient.DefaultRequestHeaders.Add("x-token", fp.GetJwToken());
    HttpResponseMessage response = _httpClient.PostAsync(_uri, content).Result;
    if (! response.IsSuccessStatusCode)
    {
        // fail
        string error = response.Content.ReadAsStringAsync().Result;
        throw new Exception(error);
    }


}
